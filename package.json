{
  "name": "smartwrite",
  "version": "1.0.0",
  "description": "SmartWrite Document Analysis Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "pdf.js": "^0.1.0"
  },
  "build": {
    "appId": "com.yourcompany.smartwrite",
    "files": [
      "**/*",
      "static/**/*",
      "workspace.html"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "**/*",
          "!node_modules",
          "!build",
          "!dist"
        ]
      }
    ]
  }
} 